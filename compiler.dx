    store_byte(ptr + 35, 1);
    store_byte(ptr + 36, 1);
    store_byte(ptr + 37, 7);
    store_byte(ptr + 38, 8);
    store_byte(ptr + 39, 1);
    store_byte(ptr + 40, 4);
    store_byte(ptr + 41, 109);
    store_byte(ptr + 42, 97);
    store_byte(ptr + 43, 105);
    store_byte(ptr + 44, 110);
    store_byte(ptr + 45, 0);
    store_byte(ptr + 46, 1);
    store_byte(ptr + 47, 10);
    store_byte(ptr + 48, 8);
    store_byte(ptr + 49, 1);
    store_byte(ptr + 50, 6);
    store_byte(ptr + 51, 0);
    store_byte(ptr + 52, 65);
    store_byte(ptr + 53, num);
