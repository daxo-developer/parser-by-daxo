fn main() {
    let file_ptr = read_file(0);
    let i = 0;
    let num = 0;
    
    while (i < 1000) {
        let current_char = load_byte(file_ptr + i);
        if (current_char == 108) {
            let c1 = load_byte(file_ptr + i + 1);
            let c2 = load_byte(file_ptr + i + 2);
            let c3 = load_byte(file_ptr + i + 3);
            let c4 = load_byte(file_ptr + i + 4);
            let c5 = load_byte(file_ptr + i + 5);
            let c6 = load_byte(file_ptr + i + 6);
            let c7 = load_byte(file_ptr + i + 7);
            
            if (c1 == 101) {
            if (c2 == 116) {
            if (c3 == 32) {
            if (c4 == 120) {
            if (c5 == 32) {
            if (c6 == 61) {
            if (c7 == 32) {
                let j = i + 8;
                let digit = load_byte(file_ptr + j);
                if (digit >= 48) {
                if (digit <= 57) {
                    num = digit - 48;
                }}
            }}}}}}}
        }
        i = i + 1;
    }
    
    if (num == 0) {
        num = 5;
    }
    
    let ptr = alloc(100);
