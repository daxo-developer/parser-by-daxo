    store_byte(ptr + 10, 2);
    store_byte(ptr + 11, 96);
    store_byte(ptr + 12, 1);
    store_byte(ptr + 13, 127);
    store_byte(ptr + 14, 0);
    store_byte(ptr + 15, 96);
    store_byte(ptr + 16, 0);
    store_byte(ptr + 17, 0);
    store_byte(ptr + 18, 2);
    store_byte(ptr + 19, 13);
    store_byte(ptr + 20, 1);
    store_byte(ptr + 21, 3);
    store_byte(ptr + 22, 101);
    store_byte(ptr + 23, 110);
    store_byte(ptr + 24, 118);
    store_byte(ptr + 25, 5);
    store_byte(ptr + 26, 112);
    store_byte(ptr + 27, 114);
    store_byte(ptr + 28, 105);
    store_byte(ptr + 29, 110);
    store_byte(ptr + 30, 116);
    store_byte(ptr + 31, 0);
